{
  "name": "bun-excel",
  "version": "1.2.1",
  "description": "High-performance, Bun-optimized library for reading and writing Excel and CSV files with streaming, styling, formulas, and hyperlinks",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "CODE_OF_CONDUCT.md",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "setup:hooks": "git config core.hooksPath .hooks",
    "test": "bun test",
    "benchmark": "bun run examples/benchmark.ts",
    "benchmark:1m": "bun run examples/benchmark-million.ts",
    "build": "rm -rf ./dist && bun build ./src/index.ts --outdir ./dist --target bun && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "tsc --noEmit && biome check . && bun test",
    "prepublishOnly": "bun run build && tsc --noEmit && biome check . && bun test"
  },
  "keywords": [
    "bun",
    "excel",
    "xlsx",
    "csv",
    "spreadsheet",
    "streaming",
    "typescript",
    "styles",
    "formulas",
    "hyperlinks"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vanloctech/bun-excel.git"
  },
  "bugs": {
    "url": "https://github.com/vanloctech/bun-excel/issues"
  },
  "homepage": "https://github.com/vanloctech/bun-excel",
  "author": "Loc Nguyen <vanloctech@gmail.com>",
  "engines": {
    "bun": ">=1.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
